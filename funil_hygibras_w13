function gM(n){return D.find(function(d){return d.nm===n;});}
function fm(n){return (n||0).toLocaleString('pt-BR',{maximumFractionDigits:0});}
function fmR(n){return 'R$\u00a0'+(n||0).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});}
function fmRs(n){return 'R$\u00a0'+(n||0).toLocaleString('pt-BR',{minimumFractionDigits:0,maximumFractionDigits:0});}
function pc(a,b){return b?((a/b)*100).toFixed(1)+'%':'—';}
function dl(c,p){
  if(!p) return '<span class="nt">—</span>';
  var d=((c-p)/p*100);
  return '<span class="'+(d>=0?'up':'dn')+'">'+(d>=0?'▲':'▼')+' '+Math.abs(d).toFixed(1)+'%</span>';
}
function dch(id){if(CH[id]){CH[id].destroy();delete CH[id];}}
function sk(vals,col){
  var mx=Math.max.apply(null,vals.concat([1]));
  return '<span class="hc-sk">'+vals.map(function(v){
    return '<span class="hc-sb" style="height:'+Math.max(2,Math.round((v/mx)*12))+'px;background:'+col+'88"></span>';
  }).join('')+'</span>';
}
function dlPlugin(color,fmt_fn){
  return {id:'dlp'+Math.floor(Math.random()*9999),afterDatasetsDraw:function(chart){
    var ctx=chart.ctx;
    chart.data.datasets.forEach(function(ds,di){
      var meta=chart.getDatasetMeta(di);
      if(meta.hidden) return;
      meta.data.forEach(function(bar,i){
        var val=ds.data[i]; if(!val) return;
        var txt=fmt_fn?fmt_fn(val):fm(val);
        ctx.save();ctx.font='500 10px sans-serif';ctx.fillStyle=color||'#888';
        ctx.textAlign='center';ctx.textBaseline='bottom';
        ctx.fillText(txt,bar.x,bar.y-3);ctx.restore();
      });
    });
  }};
}
function isDark(){return window.matchMedia('(prefers-color-scheme: dark)').matches;}
function txtC(){return isDark()?'#aaa':'#888';}

function stTag(st){
  var s=st?st.toLowerCase():'';
  if(s==='ok') return '<span class="hc-tag hc-tag-ok">OK</span>';
  if(s==='pendente') return '<span class="hc-tag hc-tag-pend">Pendente</span>';
  if(s==='higiclear') return '<span class="hc-tag hc-tag-other">Higiclear</span>';
  return '';
}

// PANORAMA
function initKPI(){
  var cur=gM('MAR'),pv=gM('FEV');
  var tk=cur.to.ve?cur.to.re/cur.to.ve:0;
  var tkP=pv.to.ve?pv.to.re/pv.to.ve:0;
  var rows=[
    {l:'Leads',      cv:fm(cur.to.le),  pv:fm(pv.to.le),   d:dl(cur.to.le,pv.to.le)},
    {l:'Orçamentos', cv:fm(cur.to.or),  pv:fm(pv.to.or),   d:dl(cur.to.or,pv.to.or)},
    {l:'Visitas',    cv:fm(cur.to.vis), pv:fm(pv.to.vis),  d:dl(cur.to.vis,pv.to.vis)},
    {l:'Vendas',     cv:fm(cur.to.ve),  pv:fm(pv.to.ve),   d:dl(cur.to.ve,pv.to.ve)},
    {l:'Receita',    cv:fmRs(cur.to.re),pv:fmRs(pv.to.re), d:dl(cur.to.re,pv.to.re)},
    {l:'Ticket médio',cv:fmR(tk),       pv:fmR(tkP),       d:dl(tk,tkP)},
    {l:'Conv. L→V',  cv:pc(cur.to.ve,cur.to.le),pv:pc(pv.to.ve,pv.to.le),d:dl(cur.to.ve/cur.to.le,pv.to.ve/pv.to.le)},
    {l:'Conv. Orc→V',cv:pc(cur.to.ve,cur.to.or),pv:pc(pv.to.ve,pv.to.or),d:dl(cur.to.ve/cur.to.or,pv.to.ve/pv.to.or)}
  ];
  document.getElementById('kgrid').innerHTML=rows.map(function(r){
    return '<div class="hc-kpi"><div class="hc-kl">'+r.l+'</div><div class="hc-kv">'+r.cv+'</div><div class="hc-kd">'+r.d+' vs fev</div><div class="hc-kp">Fev: '+r.pv+'</div></div>';
  }).join('');
}

function initFunnel(){
  var t=gM('MAR').to;
  var steps=[{l:'Leads',v:t.le,c:'#378ADD'},{l:'Qualif.',v:t.qu,c:'#BA7517'},{l:'Orçam.',v:t.or,c:'#8B5CF6'},{l:'Visitas',v:t.vis,c:'#06B6D4'},{l:'Vendas',v:t.ve,c:'#1D9E75'}];
  document.getElementById('funnel').innerHTML=steps.map(function(b){
    var w=Math.max(3,Math.round((b.v/t.le)*100));
    return '<div class="hc-fr"><div class="hc-fl">'+b.l+'</div><div class="hc-ft"><div class="hc-ff" style="width:'+w+'%;background:'+b.c+'">'+fm(b.v)+'</div></div><div class="hc-fp">'+w+'%</div></div>';
  }).join('');
}

function initInsights(){
  var mar=gM('MAR'),fev=gM('FEV');
  var items=[];
  var convL=mar.to.ve/mar.to.le;
  var convO=mar.to.or?mar.to.ve/mar.to.or:0;
  var tk=mar.to.ve?mar.to.re/mar.to.ve:0;
  var tkP=fev.to.ve?fev.to.re/fev.to.ve:0;
  var qualR=mar.to.qu/mar.to.le;

  if(mar.to.re<fev.to.re) items.push({c:'#E24B4A',t:'Receita caiu '+((1-mar.to.re/fev.to.re)*100).toFixed(0)+'% vs fevereiro ('+fmRs(fev.to.re)+'→'+fmRs(mar.to.re)+'). Atenção ao ciclo de fechamento.'});
  if(qualR>0.15) items.push({c:'#1D9E75',t:'Taxa de qualificação em '+pc(mar.to.qu,mar.to.le)+' — melhor índice do trimestre. Funil topo saudável.'});
  if(mar.to.vis>fev.to.vis) items.push({c:'#06B6D4',t:'Visitas saltaram de '+fm(fev.to.vis)+' para '+fm(mar.to.vis)+' em março — maior atividade comercial do trimestre.'});
  if(convO<0.15) items.push({c:'#BA7517',t:'Apenas '+pc(mar.to.ve,mar.to.or)+' dos orçamentos viraram venda. Revisar processo de fechamento pós-visita.'});
  if(mar.to.le>fev.to.le) items.push({c:'#1D9E75',t:'Volume de leads cresceu '+((mar.to.le/fev.to.le-1)*100).toFixed(0)+'% vs fev. Topo do funil em expansão.'});
  var bw=mar.wk.slice().sort(function(a,b){return b.re-a.re;})[0];
  if(bw.re>0) items.push({c:'#378ADD',t:'Melhor semana: '+bw.w+' ('+bw.lb+') com '+fmRs(bw.re)+' e '+bw.ve+' vendas.'});
  else items.push({c:'#BA7517',t:'Semanas W12 e W13 sem receita — vendas em pipeline ou fechamentos pós-20/03.'});

  document.getElementById('insights').innerHTML=items.map(function(i){
    return '<div class="hc-in"><div class="hc-dot" style="background:'+i.c+'"></div><span>'+i.t+'</span></div>';
  }).join('');
}

function initPanCharts(){
