  document.getElementById('abr-b').style.display=DATA.some(function(d){return d.nm==='ABR';})?'':'none';
  document.getElementById('upd').textContent='Atualizado em '+new Date().toLocaleDateString('pt-BR');

  var tabs=[{id:'panorama',l:'Panorama'},{id:'semanal',l:'Semanal'},{id:'origens',l:'Origens'}];
