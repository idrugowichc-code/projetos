}

function gL(){return DATA[DATA.length-1];}
function gP(){return DATA.length>=2?DATA[DATA.length-2]:null;}
function fm(n){return(n||0).toLocaleString('pt-BR',{maximumFractionDigits:0});}
function fR(n){return'R$ '+(n||0).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});}
function fRs(n){return'R$ '+(n||0).toLocaleString('pt-BR',{minimumFractionDigits:0,maximumFractionDigits:0});}
function pc(a,b){return b?((a/b)*100).toFixed(1)+'%':'—';}
function dl(c,p){if(!p||!c)return'<span class="nt">—</span>';var d=((c-p)/p*100);return'<span class="'+(d>=0?'up':'dn')+'">'+(d>=0?'▲':'▼')+' '+Math.abs(d).toFixed(1)+'%</span>';}
function dch(id){if(CH[id]){CH[id].destroy();delete CH[id];}}
function sk(vals,col){var mx=Math.max.apply(null,vals.concat([1]));return'<span class="sk">'+vals.map(function(v){return'<span class="sb" style="height:'+Math.max(2,Math.round((v/mx)*12))+'px;background:'+col+'88"></span>';}).join('')+'</span>';}
function dlP(col,fn){return{id:'p'+Math.floor(Math.random()*9999),afterDatasetsDraw:function(ch){var ctx=ch.ctx;ch.data.datasets.forEach(function(ds,di){var mt=ch.getDatasetMeta(di);if(mt.hidden)return;mt.data.forEach(function(b,i){var v=ds.data[i];if(!v)return;ctx.save();ctx.font='600 10px system-ui';ctx.fillStyle=col;ctx.textAlign='center';ctx.textBaseline='bottom';ctx.fillText(fn?fn(v):fm(v),b.x,b.y-3);ctx.restore();});});};};}
