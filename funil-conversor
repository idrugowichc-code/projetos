<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Funil Semanal — Higiclear & Hygibras</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#f7f6f2;--bg2:#eeecea;--sur:#fff;--bor:#d8d6cf;--txt:#1a1a18;--txt2:#6b6a64;--txt3:#a09e98;--grn:#1D9E75;--grn-bg:#e8f5ef;--grn-bd:#b2dfc9;--blu:#378ADD;--amb:#BA7517;--pur:#8B5CF6;--red:#E24B4A;--cyn:#06B6D4;--r:10px;--rs:6px}
html,body{width:100%;min-height:100vh;background:var(--bg);color:var(--txt);font-family:system-ui,-apple-system,sans-serif}
#upl{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;gap:20px;padding:32px}
.logo{font-size:12px;font-weight:600;letter-spacing:.1em;color:var(--txt2);text-transform:uppercase}
.drop{border:2px dashed var(--bor);border-radius:16px;padding:48px 56px;text-align:center;background:var(--sur);cursor:pointer;transition:all .2s;max-width:460px;width:100%}
.drop:hover,.drop.dg{border-color:var(--blu);background:#f0f6ff}
.di{font-size:36px;margin-bottom:14px;opacity:.35}
.dt{font-size:16px;font-weight:600;margin-bottom:8px}
.ds{font-size:13px;color:var(--txt2);line-height:1.6}
.dbtn{display:inline-block;margin-top:18px;padding:9px 22px;background:var(--txt);color:#fff;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer}
.dbtn:hover{opacity:.85}
#fi{display:none}
.bgs{display:flex;gap:8px;justify-content:center;flex-wrap:wrap}
.bg{font-size:11px;padding:4px 10px;border-radius:20px;background:var(--bg2);color:var(--txt2);border:0.5px solid var(--bor)}
.bg-hi{background:#e8f0ff;color:#185FA5;border-color:#b5d4f4}
.bg-hy{background:var(--grn-bg);color:#0F6E56;border-color:var(--grn-bd)}
#lod{display:none;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;gap:14px}
.spin{width:32px;height:32px;border:3px solid var(--bor);border-top-color:var(--blu);border-radius:50%;animation:sp .8s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}
.ltxt{font-size:13px;color:var(--txt2)}
#dsh{display:none;width:100%;min-height:100vh;flex-direction:column}
.bar{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;background:var(--sur);border-bottom:0.5px solid var(--bor);gap:10px;flex-wrap:wrap}
.bar-l{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.cnm{font-size:14px;font-weight:600;color:var(--txt)}
.cbg{font-size:10px;padding:3px 9px;border-radius:10px;font-weight:500}
.cbg-hi{background:#e8f0ff;color:#185FA5}
.cbg-hy{background:var(--grn-bg);color:#0F6E56}
.abr-b{font-size:10px;padding:3px 9px;border-radius:10px;background:var(--grn-bg);color:var(--grn);border:0.5px solid var(--grn-bd)}
.bar-r{display:flex;align-items:center;gap:8px}
.upd{font-size:11px;color:var(--txt2)}
.bo{font-size:12px;padding:6px 12px;border-radius:var(--rs);border:0.5px solid var(--bor);background:none;color:var(--txt);cursor:pointer}
.bo:hover{background:var(--bg)}
.bn{font-size:12px;padding:6px 12px;border-radius:var(--rs);border:none;background:var(--txt);color:#fff;cursor:pointer}
.bn:hover{opacity:.85}
.tabs{display:flex;border-bottom:0.5px solid var(--bor);padding:0 20px;background:var(--sur);overflow-x:auto;flex-shrink:0}
.tab{padding:9px 13px;font-size:12px;color:var(--txt2);cursor:pointer;border:none;border-bottom:2px solid transparent;background:none;white-space:nowrap}
.tab.on{color:var(--txt);border-bottom-color:var(--txt);font-weight:500}
.body{padding:18px 20px;width:100%;max-width:1100px}
.nota{font-size:12px;color:var(--grn);padding:9px 13px;border-radius:var(--rs);background:var(--grn-bg);border:0.5px solid var(--grn-bd);margin-bottom:14px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px}
.g4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:9px;margin-bottom:14px}
.c{background:var(--sur);border:0.5px solid var(--bor);border-radius:var(--r);padding:14px 16px;margin-bottom:14px}
.c-hl{background:var(--sur);border:0.5px solid var(--grn-bd);border-radius:var(--r);padding:14px 16px;margin-bottom:14px}
.ct{font-size:10px;font-weight:600;color:var(--txt2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px}
.ct-hl{font-size:10px;font-weight:600;color:var(--grn);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px}
.k{background:var(--bg);border-radius:var(--rs);padding:11px 13px}
.k-hl{background:var(--grn-bg);border-radius:var(--rs);padding:11px 13px;border:0.5px solid var(--grn-bd)}
.kl{font-size:10px;color:var(--txt2);text-transform:uppercase;letter-spacing:.04em;margin-bottom:4px}
.kl-hl{font-size:10px;color:var(--grn);text-transform:uppercase;letter-spacing:.04em;margin-bottom:4px}
.kv{font-size:18px;font-weight:600;color:var(--txt);line-height:1.1}
.kv-hl{font-size:18px;font-weight:600;color:var(--grn);line-height:1.1}
.kd{font-size:11px;margin-top:3px}
.kp{font-size:10px;margin-top:2px;color:var(--txt3)}
.up{color:var(--grn)}.dn{color:var(--red)}.nt{color:var(--txt3)}
.fn{display:flex;flex-direction:column;gap:6px}
.fr{display:flex;align-items:center;gap:7px}
.fl{font-size:11px;color:var(--txt2);width:70px;flex-shrink:0;text-align:right}
.ft{flex:1;background:var(--bg2);border-radius:3px;height:21px;overflow:hidden}
.ff{height:100%;border-radius:3px;display:flex;align-items:center;padding-left:7px;font-size:11px;font-weight:500;color:#fff}
.fp{font-size:11px;color:var(--txt2);width:34px;flex-shrink:0}
.ins{display:flex;flex-direction:column;gap:7px}
.in{display:flex;gap:7px;align-items:flex-start;font-size:12px;color:var(--txt2);line-height:1.5}
.dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:5px}
.pills{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.pill{font-size:12px;padding:4px 11px;border-radius:20px;cursor:pointer;border:0.5px solid var(--bor);background:none;color:var(--txt2)}
.pill.on{background:var(--bg2);color:var(--txt);border-color:var(--txt3);font-weight:500}
.pill-hl{border-color:var(--grn-bd);color:var(--grn)}
.pill-hl.on{background:var(--grn-bg)}
.tbl{width:100%;border-collapse:collapse;font-size:11px}
.tbl th{text-align:left;padding:5px 7px;color:var(--txt2);font-weight:500;border-bottom:0.5px solid var(--bor);font-size:10px;text-transform:uppercase}
.tbl td{padding:6px 7px;border-bottom:0.5px solid var(--bg2);color:var(--txt)}
.tbl .tot td{background:var(--bg2);font-weight:600}
.tbl .bst td{background:var(--grn-bg)}
.wb{display:inline-block;font-size:9px;padding:1px 5px;border-radius:3px;background:#e6f1fb;color:#185FA5;margin-left:3px}
.sk{display:inline-flex;gap:2px;align-items:flex-end;height:13px;vertical-align:middle}
.sb{width:3px;border-radius:1px}
.ob{display:flex;flex-direction:column;gap:5px}
.or{display:flex;align-items:center;gap:7px}
.ol{font-size:11px;color:var(--txt2);width:110px;flex-shrink:0;text-align:right;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ot{flex:1;background:var(--bg2);border-radius:3px;height:17px;overflow:hidden}
.of{height:100%;border-radius:3px;display:flex;align-items:center;padding-left:6px;font-size:10px;font-weight:500;color:#fff}
.on2{font-size:11px;color:var(--txt2);width:36px;flex-shrink:0;text-align:right}
.tag{display:inline-block;font-size:10px;padding:2px 6px;border-radius:6px;background:var(--bg2);color:var(--txt2)}
.tag-ok{background:var(--grn-bg);color:var(--grn)}
.tag-nok{background:#fceaea;color:var(--red)}
.tag-pend{background:#fef5e4;color:var(--amb)}
.tag-in{background:#e6f1fb;color:var(--blu)}
.tag-out{background:#fef5e4;color:var(--amb)}
.vcrd{display:flex;align-items:center;gap:9px;padding:7px 0;border-bottom:0.5px solid var(--bg2)}
.vcrd:last-child{border-bottom:none}
.vnum{font-size:11px;color:var(--txt3);width:20px;flex-shrink:0;text-align:right}
.vnm{flex:1;font-size:12px;color:var(--txt);line-height:1.4}
.vsumm{display:flex;gap:10px;margin-bottom:10px;padding-bottom:9px;border-bottom:0.5px solid var(--bg2);flex-wrap:wrap}
.vkpi{font-size:12px;color:var(--txt2)}
.vkpi strong{color:var(--txt);font-weight:500}
.cw{position:relative;width:100%}
.pane{display:none}
.pane.on{display:block}
.emp{font-size:12px;color:var(--txt2);padding:12px 0}
</style>
</head>
<body>
<div id="upl">
  <div class="logo">Funil Semanal 2026</div>
  <div class="drop" id="dz">
    <div class="di">📊</div>
    <div class="dt">Envie a planilha de funil</div>
    <div class="ds">Arraste o arquivo <strong>.xlsx</strong> aqui ou clique para selecionar.<br>Detecta automaticamente Higiclear ou Hygibras.</div>
    <label class="dbtn" for="fi">Selecionar arquivo</label>
    <input type="file" id="fi" accept=".xlsx,.xls">
  </div>
  <div class="bgs">
    <span class="bg bg-hi">FUNIL_2026_HIGICLEAR.xlsx</span>
    <span class="bg bg-hy">FUNIL_2026_HYGIBRAS.xlsx</span>
  </div>
</div>
<div id="lod"><div class="spin"></div><div class="ltxt" id="lmsg">Lendo planilha...</div></div>
<div id="dsh">
  <div class="bar">
    <div class="bar-l">
      <div class="cnm" id="cnm"></div>
      <span class="cbg" id="cbg"></span>
      <span class="abr-b" id="abr-b" style="display:none">Abr em andamento</span>
    </div>
    <div class="bar-r">
      <div class="upd" id="upd"></div>
      <button class="bo" id="exp-btn">↗ Exportar</button>
      <button class="bn" id="new-btn">Nova planilha</button>
    </div>
  </div>
  <div class="tabs" id="tabs"></div>
  <div class="body">
    <div id="pane-panorama" class="pane on"></div>
    <div id="pane-semanal" class="pane"></div>
    <div id="pane-origens" class="pane"></div>
    <div id="pane-visitas" class="pane"></div>
    <div id="pane-fechadas" class="pane"></div>
  </div>
</div>
<script>
var DATA=[],CO='',IS_HY=false,wI=0,oI=0,vI=0,fI=0,CH={};

// ── UPLOAD ──
document.getElementById('dz').addEventListener('dragover',function(e){e.preventDefault();this.classList.add('dg');});
document.getElementById('dz').addEventListener('dragleave',function(){this.classList.remove('dg');});
document.getElementById('dz').addEventListener('drop',function(e){e.preventDefault();this.classList.remove('dg');if(e.dataTransfer.files[0])go(e.dataTransfer.files[0]);});
document.getElementById('fi').addEventListener('change',function(){if(this.files[0])go(this.files[0]);});
document.getElementById('new-btn').addEventListener('click',function(){location.reload();});

function go(file){
  show('lod');hide('upl');msg('Lendo planilha...');
  var r=new FileReader();
  r.onload=function(e){
    try{
      IS_HY=file.name.toUpperCase().indexOf('HYGIBRAS')>=0;
      CO=IS_HY?'Hygibras':'Higiclear';
      msg('Processando '+CO+'...');
      // raw:true para preservar valores numéricos exatos sem conversão de data
      var wb=XLSX.read(e.target.result,{type:'array',raw:true});
      setTimeout(function(){
        try{DATA=parseWB(wb);msg('Montando dashboard...');setTimeout(build,150);}
        catch(err){show('upl');hide('lod');alert('Erro: '+err.message);}
      },80);
    }catch(err){show('upl');hide('lod');alert('Erro ao ler: '+err.message);}
  };
  r.readAsArrayBuffer(file);
}

// ── PARSER ── label-based, robusto ──
function parseWB(wb){
  var months=[];
  // Ordem correta
  var order=['JAN','FEV','MAR','ABR'];
  var sheets=[];
  order.forEach(function(mo){
    wb.SheetNames.forEach(function(sn){
      if(sn.toUpperCase().indexOf(mo)>=0&&sn.toUpperCase().indexOf('TOTAL')<0&&sn.toUpperCase().indexOf('FUNIL')>=0){
        sheets.push({sn:sn,mo:mo});
      }
    });
  });

  sheets.forEach(function(s){
    var rows=XLSX.utils.sheet_to_json(wb.Sheets[s.sn],{header:1,defval:null,raw:true,blankrows:true});
    var m;
    if(s.mo==='ABR') m=parseAbr(rows);
    else m=parseStd(rows,s.mo);
    if(m){months.push(m);}
  });
  return months;
}

// Encontra índice da linha pelo rótulo na coluna A
function findRow(rows,lbl){
  var l=lbl.toLowerCase();
  for(var i=0;i<rows.length;i++){
    var v=rows[i]&&rows[i][0];
    if(v!=null&&String(v).toLowerCase().indexOf(l)>=0) return i;
  }
  return -1;
}

function N(v){
  if(v==null) return 0;
  if(typeof v==='number') return isNaN(v)?0:v;
  var f=parseFloat(String(v).replace(',','.'));
  return isNaN(f)?0:f;
}

function parseStd(rows,nm){
  // Encontrar linha de headers ("Semanas")
  var rHdr=findRow(rows,'semanas');
  if(rHdr<0) return null;

  // Encontrar coluna "Total"
  var hdr=rows[rHdr]||[];
  var totCol=-1;
  for(var i=1;i<hdr.length;i++){
    if(hdr[i]!=null&&String(hdr[i]).trim().toLowerCase()==='total'){totCol=i;break;}
  }
  if(totCol<0) return null;

  // Linhas-chave por label
  var rDi  =findRow(rows,'dias úteis');  if(rDi<0)  rDi=findRow(rows,'dias uteis');
  var rLe  =findRow(rows,'total');       // primeira ocorrência = leads
  var rQu  =findRow(rows,'qualificados');
  var rConv=findRow(rows,'conversão');   if(rConv<0) rConv=findRow(rows,'conversao');
  var rVal =findRow(rows,'valor em vendas');

  // W-labels do cabeçalho lateral (row 0)
  var wMap={};
  var r0=rows[0]||[];
  for(var i=0;i<r0.length;i++){
    if(r0[i]&&/^W\d+/.test(String(r0[i]))){
      var lv=rows[rLe]&&rows[rLe][i+1];
      if(N(lv)>0) wMap[Math.round(N(lv))]=String(r0[i]);
    }
  }
  // Row 10 também tem W-labels na tabela lateral
  var r10=rows[10]||[];
  for(var i=0;i<r10.length;i++){
    if(r10[i]&&/^W\d+/.test(String(r10[i]))){
      var lv=rows[12]&&rows[12][i+1];
      if(N(lv)>0) wMap[Math.round(N(lv))]=String(r10[i]);
    }
  }

  // Colunas de semanas (cols 1 até totCol-1 com header não-nulo)
  var cols=[];
  for(var i=1;i<totCol;i++){if(hdr[i]!=null) cols.push(i);}

  // Atribuir W-number a cada coluna
  var firstWn=null;
  var assigned={};
  cols.forEach(function(c,idx){
    var le=rows[rLe]&&N(rows[rLe][c]);
    if(wMap[Math.round(le)]) assigned[c]=wMap[Math.round(le)];
  });
  cols.forEach(function(c,idx){
    if(assigned[c]&&firstWn===null) firstWn=parseInt(assigned[c].slice(1))-idx;
  });
  cols.forEach(function(c,idx){
    if(!assigned[c]) assigned[c]=firstWn!=null?'W'+(firstWn+idx):'';
  });

  // Orçamentos: buscar na tabela lateral (TOTAL col) e por semana
  var orcTotals=getOrcData(rows,cols,totCol);

  // Semanas
  var weeks=[];
  cols.forEach(function(c,idx){
    var le=rows[rLe]?N(rows[rLe][c]):0;
    var re=rows[rVal]?N(rows[rVal][c]):0;
    if(le===0&&re===0) return;
    weeks.push({
      lb:String(hdr[c]).trim(),w:assigned[c]||'',
      di:Math.round(rows[rDi]?N(rows[rDi][c]):0),
      le:Math.round(le),
      qu:Math.round(rows[rQu]?N(rows[rQu][c]):0),
      or:orcTotals.weeks[idx]||0,
      ve:Math.round(rows[rConv]?N(rows[rConv][c]):0),
      re:Math.round(re*100)/100
    });
  });

  // Totais
  var to={
    le:Math.round(rows[rLe]?N(rows[rLe][totCol]):0),
    qu:Math.round(rows[rQu]?N(rows[rQu][totCol]):0),
    or:orcTotals.total,
    ve:Math.round(rows[rConv]?N(rows[rConv][totCol]):0),
    re:Math.round((rows[rVal]?N(rows[rVal][totCol]):0)*100)/100,
    di:Math.round(rows[rDi]?N(rows[rDi][totCol]):0),
    vis:0
  };

  // Visitas (Hygibras: row com "TOTAL DE VISITAS")
  var vis=[];
  var rVis=findRow(rows,'total de visitas');
  if(rVis>=0){
    to.vis=Math.round(N(rows[rVis][1]));
    for(var i=rVis+1;i<rows.length;i++){
      var v=rows[i]&&rows[i][0];
      if(v==null) break;
      var s=String(v);
      if(/^(DATA|NOME VENDEDOR)/i.test(s)) break;
      var st=rows[i][1]?String(rows[i][1]).trim().toLowerCase():'';
      vis.push({nm:s,st:st});
    }
  }

  // Origens (linhas 3-7 col A = label, totCol = total)
  var oL=[];
  for(var ri=rHdr+1;ri<rLe;ri++){
    var row=rows[ri]; if(!row||!row[0]) continue;
    var lbl=String(row[0]);
    if(/coef|total|semana/i.test(lbl)) continue;
    var v=N(row[totCol]);
    if(v>0) oL.push({o:lbl,v:Math.round(v)});
  }

  // Vendas
  var sl=parseSales(rows);

  return {nm:nm,wk:weeks,to:to,oL:oL,vis:vis,sl:sl};
}

// Busca dados de Orçamentos na tabela lateral
function getOrcData(rows,cols,totCol){
  var result={weeks:[],total:0};
  cols.forEach(function(){result.weeks.push(0);});

  // Estratégia: procurar "ORÇAMENTOS" como label em qualquer célula col>=7
  for(var ri=0;ri<Math.min(rows.length,20);ri++){
    var row=rows[ri]; if(!row) continue;
    for(var ci=7;ci<row.length;ci++){
      if(row[ci]!=null&&String(row[ci]).toUpperCase().indexOf('ORÇAMENTO')>=0){
        // O valor de orçamento por semana está em [ci+1]
        // Identificar qual semana pelo lead count acima (2-3 linhas acima)
        // Mais simples: pegar o valor desta linha e verificar se é razoável
        var val=N(row[ci+1]);
        if(val>0){
          // Encontrar qual semana: lead count dessa semana deve estar em alguma linha
          // Vamos tentar associar por índice de W
          // Por ora: acumular para total se na coluna TOTAL
          var hdrRow=rows[0]||[];
          for(var ci2=ci+1;ci2<row.length;ci2++){
            if(hdrRow[ci2]&&String(hdrRow[ci2]).toUpperCase().indexOf('TOTAL')>=0){
              result.total=Math.round(N(row[ci2+1])||0);
              break;
            }
          }
        }
      }
    }
  }

  // Fallback: procurar na área do TOTAL lateral (row 10+)
  if(result.total===0){
    for(var ri=10;ri<Math.min(rows.length,18);ri++){
      var row=rows[ri]; if(!row) continue;
      for(var ci=7;ci<row.length;ci++){
        if(row[ci]!=null&&String(row[ci]).toUpperCase().indexOf('ORÇAMENTO')>=0){
          // Valor de TOTAL está algumas colunas à direita
          for(var ci2=ci+1;ci2<Math.min(row.length,ci+8);ci2++){
            var v=N(row[ci2]);
            if(v>0&&v<500){result.total=Math.round(v);break;}
          }
          if(result.total>0) break;
        }
      }
      if(result.total>0) break;
    }
  }

  return result;
}

function parseAbr(rows){
  // Ambas empresas: labels em col A, total em col 6
  // Hygibras: Total=row6, Qualificados=row7, Orçamentos=row9, Conversão=row10, Valor=row11
  // Higiclear: Total=row6 ("Total"), Qualificados=row7, Orçamentos=row9, Conversão=row10, Valor=row11

  var rDi  =findRow(rows,'dias úteis');  if(rDi<0) rDi=findRow(rows,'dias uteis');
  var rLe  =findRow(rows,'total');
  var rQu  =findRow(rows,'qualificados');
  var rOrc =findRow(rows,'orçamentos');  if(rOrc<0) rOrc=findRow(rows,'orcamentos');
  var rConv=findRow(rows,'conversão');   if(rConv<0) rConv=findRow(rows,'conversao');
  var rVal =findRow(rows,'valor em vendas');

  var di1 =rDi>=0  ?Math.round(N(rows[rDi][1])):2;
  var le1 =rLe>=0  ?Math.round(N(rows[rLe][1])):0;
  var qu1 =rQu>=0  ?Math.round(N(rows[rQu][1])):0;
  var or1 =rOrc>=0 ?Math.round(N(rows[rOrc][1])):0;
  var ve1 =rConv>=0?Math.round(N(rows[rConv][1])):0;
  var re1 =rVal>=0 ?Math.round(N(rows[rVal][1])*100)/100:0;

  var leT =rLe>=0  ?Math.round(N(rows[rLe][6])):le1;
  var quT =rQu>=0  ?Math.round(N(rows[rQu][6])):qu1;
  var orT =rOrc>=0 ?Math.round(N(rows[rOrc][6])):or1;
  var veT =rConv>=0?Math.round(N(rows[rConv][6])):ve1;
  var reT =rVal>=0 ?Math.round(N(rows[rVal][6])*100)/100:re1;
  var diT =rDi>=0  ?Math.round(N(rows[rDi][6])):20;

  var to={le:leT,qu:quT,or:orT,ve:veT,re:reT,di:20,vis:0};

  // Hygibras ABR: visitas em J5 (row4,col9) e lista a partir de I6 (row5,col8)
  var vis=[];
  if(IS_HY){
    to.vis=Math.round(N(rows[4]&&rows[4][9]));
    for(var i=5;i<rows.length;i++){
      var nm=rows[i]&&rows[i][8];
      if(nm==null) break;
      vis.push({nm:String(nm),st:''});
    }
  }

  // Origens col A, col 6 total (ou col 1 se col 6 nulo)
  var oL=[];
  for(var ri=2;ri<Math.min(rows.length,14);ri++){
    var row=rows[ri]; if(!row||!row[0]) continue;
    var lbl=String(row[0]);
    if(/coef|total|qualif|convers|valor|dias/i.test(lbl)) continue;
    if(/orcamento|orçamento/i.test(lbl)) continue;
    var v=N(row[6])||N(row[1]);
    if(v>0&&v<10000) oL.push({o:lbl,v:Math.round(v)});
  }

  // Semana única
  var wk=[{lb:'01 a 02',w:'W14',di:di1,le:le1,qu:qu1,or:or1,ve:ve1,re:re1}];

  var sl=parseSales(rows);

  return {nm:'ABR',wk:wk,to:to,oL:oL,vis:vis,sl:sl};
}

function parseSales(rows){
  var sl=[];
  var hdrR=-1;
  for(var i=0;i<rows.length;i++){
    var v=rows[i]&&rows[i][0];
    if(v&&(String(v).indexOf('Nome Vendedor')>=0||String(v).toUpperCase().indexOf('DATA')>=0)){hdrR=i;break;}
  }
  if(hdrR<0) return sl;
  for(var i=hdrR+1;i<rows.length;i++){
    var row=rows[i]; if(!row) continue;
    var dt='',cl='',og='',vd='',vl=0,ql='';
    // Formato padrão: col0=vendedor, col1=cliente, col2=valor, col3=data, col4=origem
    if(row[3]!=null){
      var d=row[3];
      var ds='';
      if(typeof d==='number'&&d>40000){var pd=XLSX.SSF.parse_date_code(d);ds=p2(pd.d)+'/'+p2(pd.m);}
      else if(typeof d==='string'&&d.indexOf('/')>=0) ds=d.substr(0,5);
      if(ds&&row[1]&&N(row[2])>0){
        dt=ds;cl=String(row[1]).substr(0,40);og=row[4]?String(row[4]):'—';
        vd=String(row[0]).replace(/TLV\s*/,'').replace(/HUNTER02\s*SUELY\/RECOMPRA/,'SUELY').replace(/HUNTER01\s*/,'').trim();
        vl=N(row[2]);
      }
    }
    // Formato ABR: col0=data, col1=cliente, col2=origem, col3=vendedor, col4=valor
    if(!dt&&row[0]!=null){
      var d=row[0];
      var ds='';
      if(typeof d==='number'&&d>40000){var pd=XLSX.SSF.parse_date_code(d);ds=p2(pd.d)+'/'+p2(pd.m);}
      else if(typeof d==='string'&&d.indexOf('/')>=0) ds=d.substr(0,5);
      if(ds&&row[1]&&N(row[4])>0){
        dt=ds;cl=String(row[1]).substr(0,40);og=row[2]?String(row[2]):'—';
        vd=row[3]?String(row[3]):'—';vl=N(row[4]);ql=row[5]?String(row[5]):'';
      }
    }
    if(dt&&cl&&vl>0) sl.push({dt:dt,cl:cl,og:og,vd:vd,vl:Math.round(vl*100)/100,ql:ql});
  }
  return sl;
}
function p2(n){return n<10?'0'+n:String(n);}

