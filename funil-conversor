function insHTML(cur,prev){
  var items=[];
  if(prev){
    if(cur.to.re>prev.to.re*1.3)items.push({c:'#1D9E75',t:'Receita de '+cur.nm+' cresceu '+((cur.to.re/prev.to.re-1)*100).toFixed(0)+'% vs '+prev.nm+' ('+fRs(prev.to.re)+'→'+fRs(cur.to.re)+').'});
    else if(cur.to.re<prev.to.re*0.7&&cur.to.re>0)items.push({c:'#E24B4A',t:'Receita de '+cur.nm+' caiu '+(((prev.to.re-cur.to.re)/prev.to.re)*100).toFixed(0)+'% vs '+prev.nm+'. Orçamentos abertos = pipeline prioritário.'});
    if(cur.to.le>prev.to.le)items.push({c:'#1D9E75',t:'Leads cresceram '+((cur.to.le/prev.to.le-1)*100).toFixed(0)+'% vs '+prev.nm+' ('+fm(prev.to.le)+'→'+fm(cur.to.le)+').'});
    if(IS_HY&&cur.to.vis>prev.to.vis)items.push({c:'#06B6D4',t:'Visitas saltaram de '+fm(prev.to.vis)+' para '+fm(cur.to.vis)+'.'});
    if(cur.to.or>0&&cur.to.ve/cur.to.or<0.3)items.push({c:'#BA7517',t:'Conv. Orc→V em '+pc(cur.to.ve,cur.to.or)+'. '+fm(cur.to.or)+' orçamentos = oportunidade de fechamento.'});
  }
  var bw=cur.wk.length?cur.wk.slice().sort(function(a,b){return b.re-a.re;})[0]:null;
  if(bw&&bw.re>0)items.push({c:'#378ADD',t:'Melhor semana: '+bw.w+' ('+bw.lb+') — '+fRs(bw.re)+', '+bw.ve+' vendas.'});
  if(!items.length)items.push({c:'#378ADD',t:'Explore as abas para análise detalhada dos dados.'});
  return'<div class="ins">'+items.map(function(i){return'<div class="in"><div class="dot" style="background:'+i.c+'"></div><span>'+i.t+'</span></div>';}).join('')+'</div>';
}

