  var slMon=DATA[isAbr?DATA.length-1:DATA.length-1],slRows=slMon&&slMon.sl?slMon.sl.slice().sort(function(a,b){return b.vl-a.vl;}):[],slTot=slRows.reduce(function(s,x){return s+x.vl;},0);
